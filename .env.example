# Public (browser + server) — safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only — never commit real values or expose to the client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: override default of 8 people per 30-minute slot
# BOOKING_SLOT_CAPACITY=8
