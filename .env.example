# Public (browser + server) — safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Preferred: new Publishable key (sb_publishable_...). Legacy anon JWT still supported:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional — shown in the hero info panel and as a clickable tel: link
# NEXT_PUBLIC_CONTACT_PHONE=(217) 555-0123

# Server-only — never commit real values or expose to the client
# Legacy JWT "service_role" key OR new Secret key (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_or_secret_key

# Admin dashboard: http://localhost:3000/admin → sign in at /admin/login
# Defaults (if unset): username coffee, password coffee. Override for production.
# ADMIN_DASHBOARD_USERNAME=coffee
# ADMIN_DASHBOARD_PASSWORD=coffee

# Optional: separate secret used to sign the admin session cookie (defaults to ADMIN_DASHBOARD_PASSWORD or "coffee")
# ADMIN_SESSION_SECRET=

# Optional: override default of 8 people per 30-minute slot
# BOOKING_SLOT_CAPACITY=8
